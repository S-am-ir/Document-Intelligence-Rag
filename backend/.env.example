# ── Database ──────────────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── LLM Providers ─────────────────────────────────────────────────────────
# Primary: OpenCode Zen (MiniMax M2.5 free)
OPENCODE_API_KEY=your_opencode_key
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
PRIMARY_MODEL=minimax-m2.5-free

# Fallback 1: Groq
GROQ_API_KEY=your_groq_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback 2: OpenRouter (DeepSeek R1 free)
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-r1:free

# Sub-agent model (used for query rewriting — lightweight)
# Defaults to Groq llama-3.3-70b-versatile

# Vision model for figure captioning
# GROQ_API_KEY above is reused — model is meta-llama/llama-4-scout-17b-16e-instruct

# ── CORS ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Ports ─────────────────────────────────────────────────────────────────
BACKEND_PORT=8000

# ── LangSmith (optional — free 5k traces/month) ───────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key
# LANGCHAIN_PROJECT=aether-os
